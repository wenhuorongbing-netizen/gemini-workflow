generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows WorkflowBlueprint[]
}

model WorkflowBlueprint {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes       String   // JSON string of React Flow nodes
  edges       String   // JSON string of React Flow edges
  updatedAt   DateTime @updatedAt

  history     ExecutionHistory[]
}

model ExecutionHistory {
  id           String   @id @default(cuid())
  workflowId   String
  workflow     WorkflowBlueprint @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status       String
  logs         String   // JSON string
  createdAt    DateTime @default(now())
}
